# Django
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,https://invento-pro-frontend.vercel.app/

# Database
DATABASE_URL=postgres://inventra_user:password@localhost:5432/inventra_db

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Inventra <noreply@inventra.io>

# Media & Static
MEDIA_ROOT=media
STATIC_ROOT=staticfiles

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Celery
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# App
APP_DOMAIN=inventra.io
FRONTEND_URL=http://localhost:3000
